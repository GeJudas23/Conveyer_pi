[Unit]
Description=Conveyor Pi Sorter
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/saiotix/conveyor_pi/main.py
WorkingDirectory=/home/saiotix/conveyor_pi
Restart=on-failure
RestartSec=5
User=saiotix
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
